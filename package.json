    "etl:montevideo-hoja": "npx tsx etl/run-montevideo-hoja.ts",
    "etl:interior-hoja": "npx tsx etl/run-interior-hoja.ts",
    "etl:nacionales-hoja-mvd": "npx tsx etl/run-nacionales-hoja-mvd.ts",
    "etl:plebiscitos-mvd": "npx tsx etl/run-plebiscitos-2024-mvd.ts",
