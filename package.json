{
  "name": "uruguay-electoral-map",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/generate-og.mjs && node scripts/gate-data.mjs && astro build",
    "generate:og": "node scripts/generate-og.mjs",
    "gate:data": "node scripts/gate-data.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "gate:perf": "node scripts/perf-budget.mjs",
    "gate:a11y": "node scripts/a11y-check.mjs",
    "gate:cwv": "node scripts/measure-cwv.mjs",
    "gate:all": "npm run gate:perf && npm run gate:a11y && npm run gate:cwv",
    "etl:montevideo": "esbuild etl/run-montevideo.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/etl-mvd.cjs --log-level=warning && node node_modules/.cache/etl-mvd.cjs",
    "etl:rivera": "esbuild etl/run-rivera.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/etl-rvr.cjs --log-level=warning && node node_modules/.cache/etl-rvr.cjs"
  },
  "dependencies": {
    "@nanostores/vue": "^0.11.0",
    "astro": "^5.18.2",
    "d3-geo": "^3.1.1",
    "maplibre-gl": "^5.24.0",
    "nanostores": "^0.11.4",
    "polygon-clipping": "^0.15.7",
    "topojson-client": "^3.1.0",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^8.2.10",
    "@astrojs/vue": "^5.1.4",
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.13",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^25.9.1",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-server": "^3.0.4",
    "@types/topojson-simplify": "^3.0.3",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.13",
    "topojson-server": "^3.0.1",
    "topojson-simplify": "^3.0.3",
    "typescript": "^5.7.0"
  }
}
