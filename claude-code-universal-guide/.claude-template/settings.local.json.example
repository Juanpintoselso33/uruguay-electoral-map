      "Bash(ls:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(curl:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(tree:*)",
      "Bash(echo:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "playwright"
  ]
}
