---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Uruguay Electoral Map', description = 'Explorador electoral de Uruguay' } = Astro.props;
---

<!doctype html>
<html lang="es-UY">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
