---
/**
 * Tabla de datos accesible equivalente al mapa (Story 1.9). HTML ESTÁTICO (no isla):
 * se renderiza en build leyendo los mismos shards que el mapa → mismo dato, sin JS,
 * navegable por teclado (alternativa textual WCAG 1.1.1 al choropleth).
 */
import { readFileSync } from 'node:fs';
import { resolveParty } from '../../lib/party-meta';
import type { VotosShard } from '../../lib/contracts';

interface Props {
  eleccion: string;
  departamento: string;
  /** Shard de votos a tabular (un nivel geográfico). Default: nivel base. */
  shard?: string;
}
const { eleccion, departamento, shard = 'votes.json' } = Astro.props;
// Epic 15: la vista nacional usa el shard '_nacional'; mostrar "Uruguay" en el caption.
const deptoLabel = departamento === '_nacional' ? 'Uruguay' : departamento;

interface OpcionesDoc {
  opciones: { opcionId: string; nombre: string }[];
}

const votes = JSON.parse(
  readFileSync(`public/data/${eleccion}/${departamento}/${shard}`, 'utf8'),
) as VotosShard;
const opcDoc = JSON.parse(
  readFileSync(`public/data/${eleccion}/${departamento}/opciones.json`, 'utf8'),
) as OpcionesDoc;
const nombrePorOpcion = new Map(opcDoc.opciones.map((o) => [o.opcionId, o.nombre]));

const filas = votes.zonas
  .map((z) => {
    const nombre = nombrePorOpcion.get(z.ganadorOpcionId) ?? z.ganadorOpcionId;
    const meta = resolveParty(nombre);
    const ganadorVotos = z.porOpcion.find((o) => o.opcionId === z.ganadorOpcionId)?.votos ?? 0;
    const pct = z.validos > 0 ? (ganadorVotos / z.validos) * 100 : 0;
    // Nivel local: el geoId es un id crudo ("montevideo-L001") → mostrar el nombre del local.
    const local = (z as { local?: { nombre?: string } }).local;
    const zona = local?.nombre ?? z.geoId;
    return { zona, sigla: meta.sigla, nombre, ganadorVotos, validos: z.validos, pct };
  })
  .sort((a, b) => a.zona.localeCompare(b.zona, 'es'));

const fmt = (n: number): string => n.toLocaleString('es-UY');

const NIVEL_LABEL: Record<string, { sing: string; plur: string }> = {
  zona: { sing: 'barrio', plur: 'barrios' },
  barrio: { sing: 'barrio', plur: 'barrios' },
  serie: { sing: 'serie', plur: 'series' },
  localidad: { sing: 'localidad', plur: 'localidades' },
  circuito: { sing: 'circuito', plur: 'circuitos' },
  local: { sing: 'local', plur: 'locales' },
};
const lbl = NIVEL_LABEL[votes.nivel] ?? { sing: votes.nivel, plur: `${votes.nivel}s` };
const nivelSingular = lbl.sing;
const nivelPlural = lbl.plur;
const nivelCol = nivelSingular.charAt(0).toUpperCase() + nivelSingular.slice(1);
---

<details class="datatable">
  <summary>Tabla de datos (accesible){' '}— {filas.length} {nivelPlural}</summary>
  <div class="datatable__scroll">
    <table>
      <caption>
        Resultados por {nivelSingular} — {deptoLabel}, {eleccion}. Partido ganador, votos del
        ganador y porcentaje sobre votos válidos. Equivalente textual del mapa.
      </caption>
      <thead>
        <tr>
          <th scope="col">{nivelCol}</th>
          <th scope="col">Ganador</th>
          <th scope="col" class="num">Votos del ganador</th>
          <th scope="col" class="num">% válidos</th>
          <th scope="col" class="num">Válidos</th>
        </tr>
      </thead>
      <tbody>
        {
          filas.map((f) => (
            <tr>
              <th scope="row">{f.zona}</th>
              <td>
                <span class="sigla">{f.sigla}</span> {f.nombre}
              </td>
              <td class="num">{fmt(f.ganadorVotos)}</td>
              <td class="num">{f.pct.toFixed(1)}%</td>
              <td class="num">{fmt(f.validos)}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</details>

<style>
  .datatable {
    margin: 1rem 0;
    padding: 0 0.75rem;
  }
  .datatable > summary {
    cursor: pointer;
    font-weight: 600;
    padding: 0.5rem 0;
  }
  .datatable__scroll {
    overflow-x: auto;
  }
  table {
    border-collapse: collapse;
    width: 100%;
    font-size: 0.8125rem;
  }
  caption {
    text-align: left;
    color: var(--color-ink-muted);
    font-size: 0.75rem;
    padding-bottom: 0.5rem;
  }
  th,
  td {
    text-align: left;
    padding: 0.375rem 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  thead th {
    border-bottom: 2px solid var(--color-border-strong);
    position: sticky;
    top: 0;
    background: var(--color-paper);
  }
  .num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .sigla {
    font-weight: 700;
  }
</style>
