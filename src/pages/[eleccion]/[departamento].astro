---
import { readFileSync } from 'node:fs';
import type { NivelGeografico } from '../../lib/contracts';
import Base from '../../layouts/Base.astro';
import ChoroplethMap from '../../components/map/ChoroplethMap.vue';
import DataTable from '../../components/a11y/DataTable.astro';
import OpcionSelector from '../../components/selectors/OpcionSelector.vue';
import OpcionAccordion from '../../components/selectors/OpcionAccordion.vue';
import LevelSelector from '../../components/selectors/LevelSelector.vue';
import EleccionSelector from '../../components/selectors/EleccionSelector.vue';
import Sello from '../../components/ui/Sello.astro';
import ShareButton from '../../components/share/ShareButton.vue';
import ExportButton from '../../components/share/ExportButton.vue';
import MapScreenshotButton from '../../components/share/MapScreenshotButton.vue';
import CompareControls from '../../components/map/CompareControls.vue';
import deptsConfig from '../../config/departments.json';

type DeptEntry = { id: string; label: string; levels: NivelGeografico[]; elecciones: string[] };
const DEPTS = deptsConfig as DeptEntry[];
const DEPT_MAP = Object.fromEntries(DEPTS.map((d) => [d.id, d]));

const ELECCION_LABELS: Record<string, string> = {
  'internas-2019':   'Elecciones Internas 2019',
  'internas-2024':   'Elecciones Internas 2024',
  'nacionales-2014': 'Elecciones Nacionales 2014',
  'nacionales-2019': 'Elecciones Nacionales 2019',
  'nacionales-2024': 'Elecciones Nacionales 2024',
  'balotaje-2014':   'Balotaje 2014',
  'balotaje-2019':   'Balotaje 2019',
  'balotaje-2024':   'Balotaje 2024',
  'plebiscito-allanamientos-2024':    'Plebiscito Allanamientos Nocturnos 2024',
  'plebiscito-seguridad-social-2024': 'Plebiscito Seguridad Social 2024',
  'departamentales-2020':             'Elecciones Departamentales y Municipales 2020',
  'departamentales-2025':             'Elecciones Departamentales y Municipales 2025',
  'referendum-luc-2022':             'Referéndum LUC 2022',
};

export function getStaticPaths() {
  const depts = deptsConfig as DeptEntry[];
  return depts.flatMap((d) =>
    d.elecciones.map((e) => ({ params: { eleccion: e, departamento: d.id } })),
  );
}

const { eleccion, departamento } = Astro.params;
const deptMeta = DEPT_MAP[departamento] ?? { id: departamento, label: departamento, levels: ['zona'], elecciones: [eleccion] };
const availableLevels: NivelGeografico[] = deptMeta.levels;
const availableElecciones: string[] = deptMeta.elecciones;
const deptLabel = deptMeta.label;

function eleccionParaDepto(dept: DeptEntry): string {
  return dept.elecciones.includes(eleccion) ? eleccion : 'internas-2024';
}

// Elecciones con catálogo de opción (Epic 10) → acordeón. internas-2024 = los 19 deptos
// (Montevideo por barrio, interior por serie); nacionales-2019/2024 = solo Montevideo (HOJA);
// balotaje/plebiscito de Montevideo = escalera PLANA (Story 10.10): el acordeón degrada a
// lista de opciones con checkbox (candidatos / Sí-No), sin árbol de HOJA.
const esFlatMontevideo =
  departamento === 'montevideo' &&
  (eleccion.startsWith('balotaje-') || eleccion.startsWith('plebiscito-') || eleccion.startsWith('referendum-'));
// departamentales-2025/2020 (todos los depts): 3 contiendas paralelas (intendente/junta/municipio) → acordeón.
const esDepartamentales2025 = eleccion === 'departamentales-2025';
const esDepartamentales2020 = eleccion === 'departamentales-2020';
const tieneCatalogoHoja =
  eleccion === 'internas-2024' ||
  eleccion === 'internas-2019' ||         // HOJA (ODN degradada + ODD), los 19 deptos (Story 7.7)
  eleccion === 'nacionales-2024' ||
  eleccion === 'nacionales-2014' ||       // HOJA degradada lema→hoja, los 19 deptos (Story 7.7)
  (eleccion === 'nacionales-2019' && departamento === 'montevideo') ||
  esFlatMontevideo ||
  esDepartamentales2025 ||
  esDepartamentales2020;

const eleccionLabel = ELECCION_LABELS[eleccion] ?? eleccion;

// Story 7.5: pregunta del plebiscito como contexto (leída del opciones.json en build).
let preguntaPlebiscito: string | null = null;
if (eleccion.startsWith('plebiscito-') || eleccion.startsWith('referendum-')) {
  try {
    const opc = JSON.parse(readFileSync(`public/data/${eleccion}/${departamento}/opciones.json`, 'utf8'));
    preguntaPlebiscito = typeof opc.pregunta === 'string' ? opc.pregunta : null;
  } catch { /* sin opciones.json → sin banner */ }
}

const titulo = `${deptLabel} — ${eleccionLabel} | Uruguay Electoral Map`;
const descripcion = `Resultados por zona del departamento ${deptLabel} en las ${eleccionLabel}.`;
const ogImagePath = `/og/${eleccion}/${departamento}.png`;
const canonicalPath = `/${eleccion}/${departamento}`;
---

<Base
  title={titulo}
  description={descripcion}
  ogImage={ogImagePath}
  canonical={canonicalPath}
>
  <main id="main-content" class="mx-auto max-w-3xl">
    <header class="masthead">
      <div>
        <h1 class="masthead__dept">{deptLabel}</h1>
        <p class="masthead__eleccion">{eleccionLabel}</p>
      </div>
      <ShareButton client:idle />
    </header>
    <!-- Pregunta del plebiscito/referéndum como contexto (Story 7.5) -->
    {preguntaPlebiscito && (
      <p class="pregunta-banner">
        <span class="pregunta-banner__prefix">Se vota Sí o No a:</span> {preguntaPlebiscito}
      </p>
    )}
    <!-- Selector de departamento — links Astro (ClientRouter navega sin reinicializar el mapa) -->
    <nav class="dept-nav" aria-label="Departamentos">
      {DEPTS.filter((d) => d.elecciones.includes(eleccion) || d.id === departamento).map((dept) => (
        <a
          href={`/${eleccionParaDepto(dept)}/${dept.id}`}
          class={`dept-nav__link${departamento === dept.id ? ' dept-nav__link--activo' : ''}`}
        >{dept.label}</a>
      ))}
    </nav>
    <!-- Selector de elección (Story 4.2) -->
    {availableElecciones.length > 1 && (
      <EleccionSelector
        elecciones={availableElecciones}
        eleccionActual={eleccion}
        departamento={departamento}
      />
    )}
    <!-- Controles de comparación dual (Story 4.3) -->
    {availableElecciones.length > 1 && (
      <CompareControls
        client:idle
        availableElecciones={availableElecciones}
        eleccionActual={eleccion}
      />
    )}
    <!-- Selector de opción — isla fuera de transition:persist, se re-monta en navegación (Story 2.2) -->
    {tieneCatalogoHoja
      ? <OpcionAccordion client:idle eleccion={eleccion} departamento={departamento} />
      : <OpcionSelector client:idle eleccion={eleccion} departamento={departamento} />}
    <!-- Selector de nivel geográfico (Story 2.5) -->
    <LevelSelector client:idle availableLevels={availableLevels} />
    <!-- transition:persist: el island MapLibre sobrevive la navegación entre departamentos (NFR1) -->
    <div id="map-persist" transition:persist>
      <ChoroplethMap
        client:load
        eleccion={eleccion}
        departamento={departamento}
        availableLevels={availableLevels}
      />
    </div>
    <DataTable eleccion={eleccion} departamento={departamento} />
    <div class="px-4 py-2 flex gap-2 flex-wrap">
      <ExportButton client:idle eleccion={eleccion} departamento={departamento} />
      <MapScreenshotButton
        client:idle
        eleccion={eleccion}
        departamento={departamento}
        deptLabel={deptLabel}
        eleccionLabel={eleccionLabel}
      />
    </div>
    <Sello eleccion={eleccion} departamento={departamento} />
  </main>
</Base>
