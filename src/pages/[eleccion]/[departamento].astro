---
import { existsSync, readFileSync } from 'node:fs';
import type { NivelGeografico } from '../../lib/contracts';
import Base from '../../layouts/Base.astro';
import ChoroplethMap from '../../components/map/ChoroplethMap.vue';
import OpcionAccordion from '../../components/selectors/OpcionAccordion.vue';
import LevelSelector from '../../components/selectors/LevelSelector.vue';
import EleccionSelector from '../../components/selectors/EleccionSelector.vue';
import CompareControls from '../../components/map/CompareControls.vue';
import Sello from '../../components/ui/Sello.astro';
import ShareButton from '../../components/share/ShareButton.vue';
import ExportButton from '../../components/share/ExportButton.vue';
import MapScreenshotButton from '../../components/share/MapScreenshotButton.vue';
import deptsConfig from '../../config/departments.json';

type DeptEntry = { id: string; label: string; levels: NivelGeografico[]; elecciones: string[] };
const DEPTS = deptsConfig as DeptEntry[];
const DEPT_MAP = Object.fromEntries(DEPTS.map((d) => [d.id, d]));

const ELECCION_LABELS: Record<string, string> = {
  'internas-2019':   'Elecciones Internas 2019',
  'internas-2024':   'Elecciones Internas 2024',
  'nacionales-2014': 'Elecciones Nacionales 2014',
  'nacionales-2019': 'Elecciones Nacionales 2019',
  'nacionales-2024': 'Elecciones Nacionales 2024',
  'balotaje-2014':   'Balotaje 2014',
  'balotaje-2019':   'Balotaje 2019',
  'balotaje-2024':   'Balotaje 2024',
  'plebiscito-allanamientos-2024':    'Plebiscito Allanamientos Nocturnos 2024',
  'plebiscito-seguridad-social-2024': 'Plebiscito Seguridad Social 2024',
  'departamentales-2020':             'Elecciones Departamentales y Municipales 2020',
  'departamentales-2025':             'Elecciones Departamentales y Municipales 2025',
  'municipales-2025':                 'Elecciones Municipales 2025',
  'referendum-luc-2022':             'Referéndum LUC 2022',
  'plebiscito-vivir-sin-miedo-2019': 'Plebiscito Vivir sin Miedo 2019',
};

export function getStaticPaths() {
  const depts = deptsConfig as DeptEntry[];
  return depts.flatMap((d) =>
    d.elecciones.map((e) => ({ params: { eleccion: e, departamento: d.id } })),
  );
}

const { eleccion, departamento } = Astro.params;
const deptMeta = DEPT_MAP[departamento] ?? { id: departamento, label: departamento, levels: ['zona'], elecciones: [eleccion] };

// Niveles por ELECCIÓN×DEPTO: los niveles se declaran por-departamento en departments.json,
// pero el dato existe por-elección. Una elección serie-only (balotajes/plebiscitos del interior)
// no tiene votes-localidad/circuito → ofrecer ese nivel rompería el mapa (ChoroplethMap lanza si
// falta el shard). Derivamos los niveles reales filtrando por la existencia del shard en disco
// (build-time). El nivel base (zona/serie) siempre mapea a votes.json. Mismo mapeo que ChoroplethMap.
function shardDeNivel(level: NivelGeografico): string {
  return level === 'circuito' ? 'votes-circuito.json'
       : level === 'local'     ? 'votes-local.json'
       : level === 'localidad' ? 'votes-localidad.json'
       : level === 'barrio'    ? 'votes-barrio.json'
       : 'votes.json';
}
const nivelesConDato = deptMeta.levels.filter((lvl) =>
  existsSync(`public/data/${eleccion}/${departamento}/${shardDeNivel(lvl)}`),
);
// Municipales: nivel ÚNICO 'municipio' (no se deriva de departments.json.levels — que es
// compartido por depto y haría colisionar serie↔municipio en votes.json). Election-aware.
const availableLevels: NivelGeografico[] = eleccion.startsWith('municipales')
  ? ['municipio']
  : (nivelesConDato.length > 0 ? nivelesConDato : deptMeta.levels);
const availableElecciones: string[] = deptMeta.elecciones;
const deptLabel = deptMeta.label;

function eleccionParaDepto(dept: DeptEntry): string {
  return dept.elecciones.includes(eleccion) ? eleccion : 'internas-2024';
}

// Selector de opción = SIEMPRE el acordeón (multi-selección + toggle {Ganador, Share, Heatmap}, Epic 13).
// Si la elección tiene catálogo de HOJA (internas, nacionales-2024/2014, departamentales, MVD plano)
// arma el árbol/escalera; si NO lo tiene (nacionales-2019 interior, balotaje/plebiscito/referéndum
// del interior) degrada a una lista plana de opciones desde opciones.json (catalogoPlanoFallback).

const eleccionLabel = ELECCION_LABELS[eleccion] ?? eleccion;

// Story 7.5: pregunta del plebiscito como contexto (leída del opciones.json en build).
let preguntaPlebiscito: string | null = null;
if (eleccion.startsWith('plebiscito-') || eleccion.startsWith('referendum-')) {
  try {
    const opc = JSON.parse(readFileSync(`public/data/${eleccion}/${departamento}/opciones.json`, 'utf8'));
    preguntaPlebiscito = typeof opc.pregunta === 'string' ? opc.pregunta : null;
  } catch { /* sin opciones.json → sin banner */ }
}

const titulo = `${deptLabel} — ${eleccionLabel} | Uruguay Electoral Map`;
const descripcion = `Resultados por zona del departamento ${deptLabel} en las ${eleccionLabel}.`;
const ogImagePath = `/og/${eleccion}/${departamento}.png`;
const canonicalPath = `/${eleccion}/${departamento}`;
---

<Base
  title={titulo}
  description={descripcion}
  ogImage={ogImagePath}
  canonical={canonicalPath}
>
  <main id="main-content" class="mx-auto max-w-3xl">
    <header class="masthead">
      <div>
        <h1 class="masthead__dept">{deptLabel}</h1>
        <p class="masthead__eleccion">{eleccionLabel}</p>
      </div>
      <ShareButton client:idle />
    </header>
    <!-- Pregunta del plebiscito/referéndum como contexto (Story 7.5) -->
    {preguntaPlebiscito && (
      <p class="pregunta-banner">
        <span class="pregunta-banner__prefix">Se vota Sí o No a:</span> {preguntaPlebiscito}
      </p>
    )}
    <!-- Selector de departamento — links Astro (ClientRouter navega sin reinicializar el mapa) -->
    <div class="dept-nav-wrap">
    <nav class="dept-nav" aria-label="Departamentos">
      {existsSync(`public/data/${eleccion}/_nacional/votes.json`) && (
        <a href={`/${eleccion}`} class="dept-nav__link dept-nav__link--nacional">🇺🇾 Nacional</a>
      )}
      {DEPTS.filter((d) => d.elecciones.includes(eleccion) || d.id === departamento).map((dept) => (
        <a
          href={`/${eleccionParaDepto(dept)}/${dept.id}`}
          class={`dept-nav__link${departamento === dept.id ? ' dept-nav__link--activo' : ''}`}
        >{dept.label}</a>
      ))}
    </nav>
    </div>
    <!-- Selector de elección (Story 4.2) — siempre visible; muestra todas las elecciones, bloqueando las sin datos -->
    <EleccionSelector
      client:idle
      eleccionesDisponibles={availableElecciones}
      eleccionActual={eleccion}
      departamento={departamento}
    />
    <!-- Toggle Zonas/Circuito (nivel geográfico) — control del mapa: va PEGADO arriba del mapa. -->
    <LevelSelector client:idle availableLevels={availableLevels} />
    <!-- Comparación entre elecciones (prototipo Fase 1): dropdown de elecciones del mismo tipo;
         marca con borde naranja las zonas donde cambió el partido ganador. -->
    <CompareControls
      client:idle
      availableElecciones={availableElecciones}
      eleccionActual={eleccion}
    />
    <!-- Map-first: el mapa (héroe) va arriba de los selectores para quedar visible sin scrollear.
         transition:persist con nombre ESTABLE ("map") → el island MapLibre sobrevive la navegación
         entre departamentos aunque vaya antes en el DOM (NFR1). -->
    <div id="map-persist" transition:persist="map">
      <ChoroplethMap
        client:load
        eleccion={eleccion}
        departamento={departamento}
        availableLevels={availableLevels}
      />
    </div>
    <!-- Selector de opción (listas) — debajo del mapa (isla fuera de persist, se re-monta, Story 2.2) -->
    <OpcionAccordion client:idle eleccion={eleccion} departamento={departamento} />
    <div class="share-actions">
      <ExportButton client:idle eleccion={eleccion} departamento={departamento} />
      <MapScreenshotButton
        client:idle
        eleccion={eleccion}
        departamento={departamento}
        deptLabel={deptLabel}
        eleccionLabel={eleccionLabel}
      />
    </div>
    <Sello eleccion={eleccion} departamento={departamento} />
  </main>
</Base>

<script>
// Scroll dept-nav to center the active department link
document.addEventListener('astro:page-load', () => {
  const nav = document.querySelector<HTMLElement>('.dept-nav');
  if (!nav) return;
  const wrap = nav.closest<HTMLElement>('.dept-nav-wrap');

  // Fades de borde: señalan que hay más departamentos para scrollear.
  const updateFades = () => {
    if (!wrap) return;
    wrap.classList.toggle('can-left', nav.scrollLeft > 4);
    wrap.classList.toggle('can-right', nav.scrollLeft < nav.scrollWidth - nav.clientWidth - 4);
  };
  nav.addEventListener('scroll', updateFades, { passive: true });
  window.addEventListener('resize', updateFades);

  let startX = 0, startScroll = 0, dragging = false;
  nav.addEventListener('mousedown', (e) => { dragging = true; startX = e.pageX; startScroll = nav.scrollLeft; nav.style.cursor = 'grabbing'; e.preventDefault(); });
  window.addEventListener('mousemove', (e) => { if (!dragging) return; nav.scrollLeft = startScroll - (e.pageX - startX); });
  window.addEventListener('mouseup', () => { dragging = false; nav.style.cursor = ''; });

  const active = nav.querySelector<HTMLElement>('.dept-nav__link--activo');
  if (active) {
    const navRect = nav.getBoundingClientRect();
    const activeRect = active.getBoundingClientRect();
    const relativeLeft = (activeRect.left - navRect.left) + nav.scrollLeft;
    const offset = relativeLeft - nav.clientWidth / 2 + active.offsetWidth / 2;
    nav.scrollLeft = Math.max(0, offset);
  }
  updateFades();
});
</script>
