---
import Base from '../../layouts/Base.astro';
import ChoroplethMap from '../../components/map/ChoroplethMap.vue';
import DataTable from '../../components/a11y/DataTable.astro';
import OpcionSelector from '../../components/selectors/OpcionSelector.vue';

// Nivel geográfico nativo por departamento (zona=barrios, serie=series electorales).
// Se actualiza al agregar cada departamento nuevo.
const DEPT_NIVEL: Record<string, 'zona' | 'serie'> = {
  montevideo: 'zona',
  rivera: 'serie',
};

export function getStaticPaths() {
  return [
    { params: { eleccion: 'internas-2024', departamento: 'montevideo' } },
    { params: { eleccion: 'internas-2024', departamento: 'rivera' } },
  ];
}

const { eleccion, departamento } = Astro.params;
const nivel = DEPT_NIVEL[departamento] ?? 'zona';
const titulo = `${departamento} — ${eleccion}`;
---

<Base title={`Uruguay Electoral Map — ${titulo}`}>
  <main class="mx-auto max-w-3xl">
    <header class="px-4 pt-4">
      <h1 class="text-xl font-bold capitalize">{departamento}</h1>
      <p class="text-sm text-gray-600">{eleccion}</p>
    </header>
    <!-- Selector de departamento — links Astro (ClientRouter navega sin reinicializar el mapa) -->
    <nav class="px-4 py-2 flex gap-3 text-sm border-b border-gray-200">
      <a href="/internas-2024/montevideo" class={`underline ${departamento === 'montevideo' ? 'font-bold' : 'text-gray-500'}`}>Montevideo</a>
      <a href="/internas-2024/rivera" class={`underline ${departamento === 'rivera' ? 'font-bold' : 'text-gray-500'}`}>Rivera</a>
    </nav>
    <!-- Selector de opción — isla fuera de transition:persist, se re-monta en navegación (Story 2.2) -->
    <OpcionSelector client:idle eleccion={eleccion} departamento={departamento} />
    <!-- transition:persist: el island MapLibre sobrevive la navegación entre departamentos (NFR1) -->
    <div id="map-persist" transition:persist>
      <ChoroplethMap client:load eleccion={eleccion} departamento={departamento} nivel={nivel} />
    </div>
    <DataTable eleccion={eleccion} departamento={departamento} />
  </main>
</Base>
