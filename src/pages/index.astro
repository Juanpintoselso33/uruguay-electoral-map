---
import Base from '../layouts/Base.astro';
import SearchBox from '../components/search/SearchBox.vue';

const ELECCION = 'internas-2024';

interface Depto {
  slug: string;
  nombre: string;
  disponible: boolean;
}

const DEPARTAMENTOS: Depto[] = [
  { slug: 'artigas',        nombre: 'Artigas',        disponible: false },
  { slug: 'canelones',      nombre: 'Canelones',       disponible: false },
  { slug: 'cerro_largo',    nombre: 'Cerro Largo',     disponible: false },
  { slug: 'colonia',        nombre: 'Colonia',         disponible: false },
  { slug: 'durazno',        nombre: 'Durazno',         disponible: false },
  { slug: 'flores',         nombre: 'Flores',          disponible: false },
  { slug: 'florida',        nombre: 'Florida',         disponible: false },
  { slug: 'lavalleja',      nombre: 'Lavalleja',       disponible: false },
  { slug: 'maldonado',      nombre: 'Maldonado',       disponible: false },
  { slug: 'montevideo',     nombre: 'Montevideo',       disponible: true  },
  { slug: 'paysandu',       nombre: 'Paysandú',        disponible: false },
  { slug: 'rio_negro',      nombre: 'Río Negro',       disponible: false },
  { slug: 'rivera',         nombre: 'Rivera',           disponible: true  },
  { slug: 'rocha',          nombre: 'Rocha',            disponible: false },
  { slug: 'salto',          nombre: 'Salto',            disponible: false },
  { slug: 'san_jose',       nombre: 'San José',         disponible: false },
  { slug: 'soriano',        nombre: 'Soriano',          disponible: false },
  { slug: 'tacuarembo',     nombre: 'Tacuarembó',       disponible: false },
  { slug: 'treinta_y_tres', nombre: 'Treinta y Tres',  disponible: false },
];
---

<Base
  title="Mapa Electoral Uruguay — Internas 2024"
  description="Explorá los resultados de las elecciones internas 2024 por departamento y barrio. Datos del escrutinio definitivo de la Corte Electoral."
>
  <main class="portada">
    <header class="portada__hero">
      <h1 class="portada__titulo">Mapa Electoral Uruguay</h1>
      <p class="portada__subtitulo">Internas 2024 — escrutinio definitivo</p>
      <p class="portada__fuente">
        Fuente: <a href="https://www.corteelectoral.gub.uy/" target="_blank" rel="noopener">Corte Electoral Uruguay</a>
      </p>
    </header>

    <SearchBox client:idle />

    <section class="portada__seleccion" aria-labelledby="seleccion-titulo">
      <h2 id="seleccion-titulo" class="portada__seleccion-titulo">Elegí un departamento</h2>
      <ul class="portada__grid" role="list">
        {DEPARTAMENTOS.map((d) =>
          d.disponible ? (
            <li>
              <a
                href={`/${ELECCION}/${d.slug}`}
                class="portada__card portada__card--disponible"
              >{d.nombre}</a>
            </li>
          ) : (
            <li>
              <span
                class="portada__card portada__card--prox"
                aria-disabled="true"
                title="Próximamente"
              >
                {d.nombre}
                <small class="portada__prox-badge">Próximamente</small>
              </span>
            </li>
          )
        )}
      </ul>
    </section>
  </main>
</Base>

<style>
.portada {
  max-width: 720px;
  margin: 0 auto;
  padding: 2rem 1rem 4rem;
}

.portada__hero {
  margin-bottom: 2.5rem;
}

.portada__titulo {
  font-size: clamp(1.5rem, 5vw, 2.25rem);
  font-weight: 800;
  color: #111827;
  line-height: 1.15;
  margin: 0 0 0.375rem;
}

.portada__subtitulo {
  font-size: 1.0625rem;
  color: #374151;
  margin: 0 0 0.5rem;
}

.portada__fuente {
  font-size: 0.8125rem;
  color: #9ca3af;
  margin: 0;
}

.portada__fuente a {
  color: #6b7280;
  text-underline-offset: 2px;
}

.portada__seleccion-titulo {
  font-size: 1rem;
  font-weight: 600;
  color: #374151;
  margin: 0 0 1rem;
}

.portada__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 0.625rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.portada__card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  min-height: 52px;
  padding: 0.625rem 0.875rem;
  border-radius: 0.5rem;
  font-size: 0.9375rem;
  font-weight: 600;
  text-decoration: none;
  line-height: 1.3;
  transition: background 0.12s, border-color 0.12s;
}

.portada__card--disponible {
  background: #ffffff;
  border: 1.5px solid #d1d5db;
  color: #111827;
  cursor: pointer;
}

.portada__card--disponible:hover {
  background: #f3f4f6;
  border-color: #9ca3af;
}

.portada__card--disponible:focus-visible {
  outline: 2px solid #111827;
  outline-offset: 2px;
}

.portada__card--prox {
  background: #f9fafb;
  border: 1.5px solid #e5e7eb;
  color: #9ca3af;
  cursor: default;
}

.portada__prox-badge {
  display: block;
  font-size: 0.625rem;
  font-weight: 400;
  color: #d1d5db;
  margin-top: 0.125rem;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}
</style>
